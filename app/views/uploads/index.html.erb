<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Uploaded Documents</h1>
    <%= link_to 'New Upload', new_upload_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium" %>
  </div>

  <% if @uploads.any? %>
    <div class="bg-white shadow-md rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @uploads.each do |upload| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= upload.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(upload.created_at) %> ago</td>


              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <%= link_to 'View Questions', upload, class: "text-blue-600 hover:text-blue-900 mr-3" %>

                <!-- Updated delete link with data-turbo-method -->
                <%= link_to 'Delete', upload,
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: 'Are you sure you want to delete this upload and all its questions?'
                      },
                      class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow-md rounded-lg p-6 text-center">
      <p class="text-gray-500">No documents uploaded yet.</p>
      <%= link_to 'Upload your first document', new_upload_path, class: "inline-block mt-4 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium" %>
    </div>
  <% end %>
</div>
