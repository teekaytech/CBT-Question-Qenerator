<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800"><%= @upload.name %></h1>
    <div class="flex items-center space-x-4">
      <%= link_to (@upload.show_answers? ? 'Hide answers' : 'Show answers'), toggle_show_answers_upload_path(@upload), data: { turbo_method: :patch }, class: "text-green-600 hover:text-green-800 mr-3" %>
      <%= link_to 'Back to uploads', uploads_path, class: "text-blue-600 hover:text-blue-800" %>
    </div>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Objective Questions</h2>

    <% if @objective_questions.any? %>
      <% @objective_questions.each_with_index do |question, index| %>
        <div class="bg-white shadow-md rounded-lg p-6 mb-4">
          <p class="font-medium text-lg mb-3"><%= index + 1 %>. <%= question.content %></p>
          <div class="ml-4">
            <% question.options.each_with_index do |option, opt_index| %>
              <div class="flex items-center mb-2">
                <span class="font-medium mr-2"><%= ('A'.ord + opt_index).chr %>.</span>
                <span class="<%= option.correct && @upload.show_answers? ? 'text-green-600 font-semibold' : 'text-gray-700' %>">
                  <%= option.content %>
                  <% if option.correct && @upload.show_answers? %>
                    <span class="ml-2 text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Correct Answer</span>
                  <% end %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white shadow-md rounded-lg p-6 text-center">
        <p class="text-gray-500">No objective questions generated yet.</p>
      </div>
    <% end %>
  </div>

  <div>
    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Theory Questions</h2>

    <% if @theory_questions.any? %>
      <% @theory_questions.each_with_index do |question, index| %>
        <div class="bg-white shadow-md rounded-lg p-6 mb-4">
          <p class="font-medium text-lg"><%= index + 1 %>. <%= question.content %></p>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white shadow-md rounded-lg p-6 text-center">
        <p class="text-gray-500">No theory questions generated yet.</p>
      </div>
    <% end %>
  </div>
</div>
